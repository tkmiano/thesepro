# ============================================================
# ThèsePro — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# URL du projet Supabase (visible dans Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Clé publique anon (safe à exposer côté client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service role — NE JAMAIS exposer côté client (SSR/webhooks uniquement)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ────────────────────────────────────────────────────
# Clé secrète (sk_test_... en dev, sk_live_... en production)
STRIPE_SECRET_KEY=sk_test_...

# Clé publique (pk_test_... en dev, pk_live_... en production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret du webhook Stripe (obtenu dans Dashboard → Webhooks)
# En dev avec Stripe CLI : stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Application ───────────────────────────────────────────────
# URL publique de l'app (sans slash final)
# Dev : http://localhost:3000
# Prod : https://thesepro.fr
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nom de l'application (affiché dans les emails)
NEXT_PUBLIC_APP_NAME=ThèsePro

# ── Resend (emails transactionnels) ──────────────────────────
# Clé API Resend (https://resend.com → API Keys)
RESEND_API_KEY=re_...

# Adresse expéditeur — doit correspondre à un domaine vérifié dans Resend
RESEND_FROM_EMAIL=ThèsePro <noreply@thesepro.fr>
